{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hyperscanning config",
  "type": "object",
  "properties": {
    "paths": {
      "type": "object",
      "properties": {
        "bids_root": {"type": "string", "minLength": 1},
        "out_dir": {"type": "string", "minLength": 1},
        "lm_feature_root": {"type": "string", "minLength": 1},
        "results_root": {"type": "string", "minLength": 1},
        "reports_root": {"type": "string", "minLength": 1},
        "precomputed_ica_root": {"type": "string", "minLength": 1},
        "annotation_root": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "debug": {"type": "object", "additionalProperties": true},
    "subjects": {"type": "object", "additionalProperties": true},
    "tasks": {"type": "object", "additionalProperties": true},
    "runs": {"type": "object", "additionalProperties": true},
    "eeg": {"type": "object", "additionalProperties": true},
    "annotations": {"type": "object", "additionalProperties": true},
    "features": {
      "type": "object",
      "properties": {
        "continuous": {"type": "object", "additionalProperties": true},
        "envelope": {"type": "object", "additionalProperties": true},
        "pitch": {"type": "object", "additionalProperties": true},
        "formants": {"type": "object", "additionalProperties": true},
        "stanza_pos": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "language": {"type": "string", "minLength": 1},
            "processors": {"type": "string", "minLength": 1},
            "resources_dir": {
              "type": ["string", "null"],
              "minLength": 1
            },
            "allow_download": {"type": "boolean"},
            "preserve_unmapped_rows": {"type": "boolean"},
            "fail_on_mapping_error": {"type": "boolean"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "trf": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "predictors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "target_sfreq": {"type": "number", "exclusiveMinimum": 0},
        "lags": {
          "type": "object",
          "properties": {
            "tmin_seconds": {"type": "number"},
            "tmax_seconds": {"type": "number"}
          },
          "additionalProperties": true
        },
        "conversation": {
          "type": "object",
          "properties": {
            "duration_seconds": {"type": "number", "exclusiveMinimum": 0},
            "start_source": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "segmentation": {"type": "object", "additionalProperties": true},
        "cv": {"type": "object", "additionalProperties": true},
        "hyperparameters": {"type": "object", "additionalProperties": true},
        "model": {"type": "object", "additionalProperties": true},
        "scoring": {"type": "object", "additionalProperties": true},
        "outputs": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": true
    },
    "preprocessing": {
      "type": "object",
      "properties": {
        "montage": {
          "type": "object",
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "on_missing": {"type": "string", "minLength": 1},
            "match_case": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "downsample": {
          "type": "object",
          "properties": {
            "sfreq_hz": {"type": "number", "exclusiveMinimum": 0}
          },
          "additionalProperties": true
        },
        "filter": {
          "type": "object",
          "properties": {
            "l_freq_hz": {"type": "number"},
            "h_freq_hz": {"type": "number"}
          },
          "additionalProperties": true
        },
        "ica": {
          "type": "object",
          "properties": {
            "path_pattern": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "interpolation": {
          "type": "object",
          "properties": {
            "method": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "rereference": {
          "type": "object",
          "properties": {
            "method": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "output": {
          "type": "object",
          "properties": {
            "save_intermediates": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "pipeline_order": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "save_intermediates": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "epochs": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
