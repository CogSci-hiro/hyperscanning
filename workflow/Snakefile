from snakemake.io import expand

from pathlib import Path
import shlex
import sys
from typing import List
import yaml

DEFAULT_CONFIG_PATH = "config/config.yaml"
configfile: DEFAULT_CONFIG_PATH
ACTIVE_CONFIG_PATH = Path(str(globals().get("configfile", DEFAULT_CONFIG_PATH)))


def _load_yaml_mapping(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as f:
        data = yaml.safe_load(f)
    if data is None:
        return {}
    if not isinstance(data, dict):
        raise ValueError(f"Expected mapping config in {path}, got {type(data)}")
    return data


def _load_section(section_name: str, *, external_precedence: bool = False) -> dict:
    base_section = config.get(section_name, {})
    if base_section is None:
        base_section = {}
    if not isinstance(base_section, dict):
        raise ValueError(f"Expected mapping for config section {section_name!r}, got {type(base_section)}")

    section_path = ACTIVE_CONFIG_PATH.with_name(f"{section_name}.yaml")
    external_section = {}
    if section_path.exists():
        external_cfg = _load_yaml_mapping(section_path)
        external_section = external_cfg.get(section_name, {})
        if external_section is None:
            external_section = {}
        if not isinstance(external_section, dict):
            raise ValueError(
                f"Expected mapping for config section {section_name!r} in {section_path}, got {type(external_section)}"
            )

    if external_precedence:
        return {**dict(base_section), **dict(external_section)}
    return {**dict(external_section), **dict(base_section)}


def _config_signature(*parts: dict) -> str:
    return yaml.safe_dump(list(parts), sort_keys=True)


PREPROCESSING = _load_section("preprocessing")
FEATURES = _load_section("features")
TRF = _load_section("trf", external_precedence=True)
PATHS = _load_section("paths")

