from snakemake.io import expand

from pathlib import Path
from typing import List
import yaml

CONFIG_PATH = "config/config.yaml"
configfile: CONFIG_PATH


def _load_yaml_mapping(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as f:
        data = yaml.safe_load(f)
    if data is None:
        return {}
    if not isinstance(data, dict):
        raise ValueError(f"Expected mapping config in {path}, got {type(data)}")
    return data


def _merge_mapping_sections(external: dict, base: dict, *, sections: tuple[str, ...]) -> dict:
    merged = dict(external)
    for section in sections:
        merged[section] = {**dict(external.get(section, {})), **dict(base.get(section, {}))}
    for key, value in base.items():
        if key in sections:
            continue
        merged[key] = value
    return merged


_preprocessing_config_path = Path(CONFIG_PATH).with_name("preprocessing.yaml")
if _preprocessing_config_path.exists():
    _preprocessing_cfg = _load_yaml_mapping(_preprocessing_config_path)
    config.update(_merge_mapping_sections(_preprocessing_cfg, config, sections=("preprocessing",)))

_paths_config_path = Path(CONFIG_PATH).with_name("paths.yaml")
if _paths_config_path.exists():
    _paths_cfg = _load_yaml_mapping(_paths_config_path)
    config.update(_merge_mapping_sections(_paths_cfg, config, sections=("paths",)))

# In Snakefile (global)
wildcard_constraints:
    subject="sub-\\d{3}",
    task="[A-Za-z0-9_-]+",
    run="\\d+"

